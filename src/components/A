# 2) PARSE XML
# =========================
def _get_text(el) -> str:
    if el is None or el.text is None:
        return ""
    return el.text.strip()


def parse_qty_br(qty_str: str) -> int:
    # '1,000' -> 1
    s = (qty_str or "").strip()
    if not s:
        return 0
    s = s.replace(".", "")
    if "," in s:
        s = s.split(",")[0]
    s = re.sub(r"[^\d-]", "", s)
    try:
        return int(s) if s else 0
    except:
        return 0


def parse_xml_items(xml_path: Path):
    tree = ET.parse(xml_path)
    root = tree.getroot()

    header = root.find("header")
    empresa = _get_text(header.find("cab-empresa")) if header is not None else ""
    filial = _get_text(header.find("cab-filial")) if header is not None else ""
    equipe = _get_text(header.find("cab-equipe")) if header is not None else ""
    depositos = _get_text(header.find("cab-depositos")) if header is not None else ""

    items = []
    detail = root.find("detail")
    if detail is None:
        return (empresa, filial, equipe, depositos, items)

    for rec in detail.findall("record"):
        codigo = _get_text(rec.find("det-material-a"))
        descricao = _get_text(rec.find("det-descricao"))
        qty_raw = _get_text(rec.find("det-quantidade"))
        local = _get_text(rec.find("det-prateleira"))

        quantidade = parse_qty_br(qty_raw)

        if not codigo and not descricao:
            continue

        items.append(
            {"codigo": codigo, "descricao": descricao, "quantidade": quantidade, "local": local}
        )

    return (empresa, filial, equipe, depositos, items)


