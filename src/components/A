def preencher_deposito_e_fechar_modal(page, codigo="ALMOX") -> None:
    print(f"⌨️ Preenchendo depósito com: {codigo}")
    page.wait_for_timeout(1200)
    page.keyboard.type(codigo, delay=100)
    page.keyboard.press("Enter")
    page.wait_for_timeout(500)
    page.keyboard.press("Enter")

    page.wait_for_timeout(800)

    # seu X original
    for fr in page.frames:
        try:
            x = fr.locator("span.class_icon_fechar_janela.icon-controller.icon-fechar").first
            if x.count() > 0:
                x.dispatch_event("click")
                print("✅ Modal do depósito fechado (X).")
