def find_frame_by_text(page, text, tries=80, sleep_ms=500):
    for _ in range(tries):
        for f in page.frames:
            try:
                if f.locator(f"text={text}").count() > 0:
                    return f
            except Exception:
                pass
        page.wait_for_timeout(sleep_ms)
    return None


def set_toggle_off_near_text(frame, text_regex: re.Pattern) -> bool:
    try:
        t = frame.get_by_text(text_regex).first
        if t.count() == 0:
            return False
        t.scroll_into_view_if_needed()

        container = t.locator("xpath=ancestor::*[self::tr or self::td or self::div or self::fieldset][1]")
        cb = container.locator("input[type='checkbox']")
        if cb.count() == 0:
            cb = t.locator("xpath=following::input[@type='checkbox'][1]")
        if cb.count() == 0:
            return False

        el = cb.first
        try:
            if el.is_checked():
                el.uncheck(timeout=3000)
        except Exception:
            handle = el.element_handle()
            frame.evaluate(
                """(el) => {
                    el.checked = false;
                    el.dispatchEvent(new Event('input', { bubbles: true }));
                    el.dispatchEvent(new Event('change', { bubbles: true }));
                }""",
                handle,
            )
        return True
    except Exception:
        return False


def disable_print_obsolete(page) -> bool:
    patterns = [
        re.compile(r"imprime\s+itens\s+obsolet", re.I),
        re.compile(r"itens\s+obsolet", re.I),
        re.compile(r"\bobsolet", re.I),
    ]
    page.wait_for_timeout(1200)
    for _ in range(1, 9):
        for fr in page.frames:
            try:
                for pat in patterns:
                    if set_toggle_off_near_text(fr, pat):
                        print("✅ 'Imprime Itens Obsoletos' desativado.")
                        return True
            except Exception:
                pass
        page.wait_for_timeout(700)
    print("⚠️ Não consegui desativar 'Imprime Itens Obsoletos'.")
    return False


def click_filtros_especificos(page, frame_hint=None) -> bool:
    targets = [frame_hint] if frame_hint else []
    targets.extend(page.frames)
    for fr in targets:
        try:
            loc = fr.locator("text=Filtros Específicos").first
            if loc.count() > 0:
                loc.scroll_into_view_if_needed()
                loc.click(timeout=5000)
                print("✅ Cliquei em 'Filtros Específicos'.")
                return True
        except Exception:
            pass
    print("⚠️ Não consegui clicar em 'Filtros Específicos'.")
    return False


def esperar_sumir_aguarde(page, timeout_ms=600000):
    for _ in range(int(timeout_ms / 500)):
        vis = False
        for fr in page.frames:
            try:
                loc = fr.locator("text=Por favor, aguarde").first
                if loc.count() > 0 and loc.is_visible():
                    vis = True
                    break
            except Exception:
                pass
        if not vis:
            return True
        page.wait_for_timeout(500)
    return False


def achar_frame_com_botao_gerar(page):
