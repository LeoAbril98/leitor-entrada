        except Exception:
            pass

    # fallback
    for fr in page.frames:
        for sel in ["text=Fechar", "text=Cancelar", "button:has-text('Fechar')", "button:has-text('Cancelar')"]:
            try:
                b = fr.locator(sel).first
                if b.count() > 0 and b.is_visible():
                    b.click(timeout=3000)
                    print("✅ Modal do depósito fechado (fallback).")
                    return
            except Exception:
                pass

    print("⚠️ Não consegui confirmar o fechamento do modal (talvez já fechou).")


