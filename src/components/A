# 3) ENVIAR SUPABASE
# =========================
def _sb_insert_one(table: str, payload: dict) -> dict:
    url = f"{SUPABASE_URL}/rest/v1/{table}"
    h = _sb_headers()
    h["Prefer"] = "return=representation"
    r = requests.post(url, headers=h, json=[payload], timeout=60)
    r.raise_for_status()
    data = r.json()
    if not data:
        raise RuntimeError("Supabase não retornou registro inserido.")
    return data[0]


def _sb_upsert_batch(table: str, rows: list[dict], on_conflict: str):
    if not rows:
        return
    url = f"{SUPABASE_URL}/rest/v1/{table}?on_conflict={on_conflict}"
    h = _sb_headers()
    h["Prefer"] = "resolution=merge-duplicates,return=minimal"
    r = requests.post(url, headers=h, json=rows, timeout=120)
    r.raise_for_status()


def _sb_delete_old_inventories(deposito: str):
    """
    Deleta os inventários anteriores deste mesmo depósito.
    Se o banco de dados tiver as FKs configuradas com ON DELETE CASCADE,
    isso deletará também os itens em `inventario_itens`.
    Caso contrário, você precisaria deletar os itens primeiro:
      DELETE FROM inventario_itens WHERE inventario_id IN (...)
    Mas deletar o inventario_pai via REST faz isso automático (se o BD permitir cascade).
    Abaixo, vamos apagar todos os inventários com `depositos` = deposito.
    """
    url = f"{SUPABASE_URL}/rest/v1/{TBL_INV}?depositos=eq.{deposito}"
    h = _sb_headers()
    # Prefer return=minimal: não precisa retornar os dados deletados
    h["Prefer"] = "return=minimal"
    r = requests.delete(url, headers=h, timeout=60)
    # Ignora 404/400 caso a tabela esteja vazia, mas pega outros erros:
    if r.status_code >= 400 and r.status_code != 404:
        raise RuntimeError(f"Falha ao deletar inventário antigo: {r.text}")


def enviar_para_supabase(meta, items, xml_url: str):
    empresa, filial, equipe, depositos = meta
    
    # 1. Passo Crítico: DELETAR O INVENTÁRIO ANTIGO DESTE DEPÓSITO PARA NÃO SOMAR/DUPLICAR
    if depositos:
        print(f"🧹 Deletando inventários antigos do depósito: {depositos}")
        _sb_delete_old_inventories(depositos)

    # 2. Continua inserção normal
    criado_em = datetime.now(timezone.utc).isoformat()

    inv_row = _sb_insert_one(
        TBL_INV,
        {
            "empresa": empresa,
            "filial": filial,
            "equipe": equipe,
            "depositos": depositos,
            "xml_url": xml_url,
            "criado_em": criado_em,
        },
    )
    inv_id = inv_row["id"]

    rows = [
        {
            "inventario_id": inv_id,
            "codigo": it["codigo"],
            "descricao": it["descricao"],
            "quantidade": it["quantidade"],
            "local": it["local"],
        }
        for it in items
    ]

    sent = 0
    for batch in _chunks(rows, BATCH_SIZE):
        _sb_upsert_batch(TBL_ITENS, batch, on_conflict="inventario_id,codigo")
        sent += len(batch)

    return inv_id, sent


# =========================
# PIPELINE COMPLETO
# =========================
def pipeline_atualizar(deposito="ALMOX", headless=False):
    xml_url, xml_path = gerar_xml_e_pegar_url(deposito=deposito, headless=headless)
    empresa, filial, equipe, depositos, items = parse_xml_items(xml_path)
    inv_id, sent = enviar_para_supabase((empresa, filial, equipe, depositos), items, xml_url=xml_url)
    return {
        "inventario_id": inv_id,
        "itens": sent,
        "empresa": empresa,
        "filial": filial,
        "equipe": equipe,
        "depositos": depositos,
        "xml_url": xml_url,
        "xml_path": str(xml_path),
    }

