# 1) GERAR e BAIXAR XML
# =========================
def gerar_xml_e_pegar_url(deposito: str = "ALMOX", headless: bool = False):
    """
    Roda o MK, clica gerar, captura a URL real do XML na rede e baixa o arquivo.
    Retorna: (xml_url, xml_path)
    """
    xml_url_holder = {"url": None}

    with sync_playwright() as p:
        browser = p.chromium.launch(headless=headless, slow_mo=80)
        context = browser.new_context(ignore_https_errors=True, accept_downloads=True)
        page = context.new_page()
        page.set_default_timeout(60000)

        def on_response(resp):
            try:
                url = resp.url
                if XML_RE.search(url) and xml_url_holder["url"] is None:
                    xml_url_holder["url"] = url
            except Exception:
                pass

        context.on("response", on_response)

        try:
            # login
            page.goto(MK_LOGIN, wait_until="domcontentloaded")
            page.get_by_placeholder("Ex: Softdib").click()
            page.get_by_text(MK_EMPRESA, exact=False).click()
            page.get_by_placeholder("Nome do Usuário").fill(MK_USUARIO)
            page.get_by_placeholder("Senha do Usuário").fill(MK_SENHA)
            page.get_by_role("button", name=re.compile("Acessar", re.I)).click()

            # abre SGM961
            page.wait_for_selector("#SGM961_005", state="visible")
            page.locator("#SGM961_005").click()

            # espera frame
            frame = find_frame_by_text(page, MK_TITULO_TELA)
            if not frame:
                raise RuntimeError("Não achei o frame do SGM961.")

            print("2) Configurando opções...")
            disable_print_obsolete(page)
            click_filtros_especificos(page, frame_hint=frame)

            # depósito
            print("3) Selecionando Depósito...")
            if click_selecionar_deposito(page):
                preencher_deposito_e_fechar_modal(page, codigo=deposito)

            # gerar
            print("5) Gerando inventário (capturando o XML REAL RGM961.REL*.xml)...")
            frame_gerar = achar_frame_com_botao_gerar(page)
            if not frame_gerar:
                raise RuntimeError("Não encontrei o botão #bGerar.")

            # clique gerar (pode abrir aba ou não)
            try:
                with context.expect_page(timeout=15000):
                    frame_gerar.locator("#bGerar").first.click(timeout=10000, no_wait_after=True)
            except PWTimeoutError:
                frame_gerar.locator("#bGerar").first.click(timeout=10000, no_wait_after=True)

            # aguarde finalizar
            esperar_sumir_aguarde(page, timeout_ms=600000)

            # aguarda XML aparecer na rede
            for _ in range(600):
                if xml_url_holder["url"]:
                    break
                page.wait_for_timeout(1000)

            xml_url = xml_url_holder["url"]
            if not xml_url:
                raise RuntimeError("Não capturei a URL do XML real (RGM961.REL*.xml).")

            # baixa via sessão logada
            r = context.request.get(xml_url, timeout=600000)
            if not r.ok:
                raise RuntimeError(f"Falha ao baixar XML. Status={r.status}")

            xml_path = DOWNLOAD_DIR / "inventario_real.xml"
            # Garante que a pasta (ex: /tmp) existe antes de salvar
            xml_path.parent.mkdir(parents=True, exist_ok=True)
            xml_path.write_bytes(r.body())

            return xml_url, xml_path

        finally:
            browser.close()


